{
  "name": "homes-map",
  "private": true,
  "version": "0.1.0",
  "description": "Simplify the interaction between tenants, landlords, and banks about a property",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @homes-map/api dev\" \"pnpm --filter @homes-map/web dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.3.3",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.5.0"
}
